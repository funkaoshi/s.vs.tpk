{{- $postSections := slice "blog" "review" "microblog" "play-report" "link" "meta" -}}
{{- $posts := where .Site.RegularPages "Section" "in" $postSections -}}
{{- $latest := index $posts 0 -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\"?>" | safeHTML }}
<feed xmlns="http://www.w3.org/2005/Atom">
  <id>{{ .Site.BaseURL }}</id>
  <title>{{ .Site.Title }}</title>
  <updated>{{ $latest.Date.Format "2006-01-02T15:04:05Z07:00" }}</updated>
  <link type="application/atom+xml" rel="self" href="{{ "atom.xml" | absURL }}"/>
  <link type="text/html" rel="alternate" href="{{ .Site.BaseURL }}"/>
  <author>
    <name>{{ .Site.Params.authorName }}</name>
    <email>{{ .Site.Params.authorEmail }}</email>
    <uri>{{ .Site.Params.authorURI }}</uri>
  </author>
  <generator>Hugo</generator>
  <rights>© {{ now.Format "2006" }} {{ .Site.Params.authorName }}</rights>
  {{- range $posts }}
  <entry>
    <id>{{ .Permalink }}</id>
    <title>{{ .Title }}</title>
    <updated>{{ .Date.Format "2006-01-02T15:04:05Z07:00" }}</updated>
    <author>
      <name>{{ $.Site.Params.authorName }}</name>
      <uri>{{ $.Site.Params.authorURI }}/</uri>
    </author>
    <content type="html">{{ printf "<![CDATA[%s]]>" .Content | safeHTML }}</content>
    <link type="text/html" rel="alternate" href="{{ .Permalink }}"/>
    <published>{{ .Date.Format "2006-01-02T15:04:05Z07:00" }}</published>
  </entry>
  {{- end }}
</feed>
