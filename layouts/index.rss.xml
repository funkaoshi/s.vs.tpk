{{- $postSections := slice "blog" "review" "microblog" "play-report"  -}}
{{- $posts := where .Site.RegularPages "Section" "in" $postSections -}}
{{- $latest := index $posts 0 -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ .Site.Title }}</title>
    <link>{{ .Site.BaseURL }}</link>
    <atom:link href="{{ "rss.xml" | absURL }}" rel="self" type="application/rss+xml" />
    <description>{{ .Site.Params.description }}</description>
    <language>{{ .Site.LanguageCode }}</language>
    <generator>Hugo</generator>
    <lastBuildDate>{{ $latest.Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    {{- range $posts }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      {{ with $.Site.Params.authorEmail }}<author>{{ . }}{{ with $.Site.Params.authorName }} ({{ . }}){{ end }}</author>{{ end }}
      <guid>{{ .Permalink }}</guid>
      <description>{{ printf "<![CDATA[%s]]>" .Content | safeHTML }}</description>
    </item>
    {{- end }}
  </channel>
</rss>
